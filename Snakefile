configfile: "defaults/config.yaml"

include: "rules/sequence_counts.smk"
include: "rules/mlr_estimates.smk"
include: "rules/fitness_flux_analysis.smk"
include: "rules/lineage_deltas_analysis.smk"

# Default target: the full workflow, including the analysis results/ tables.
# Defined after the includes so it can reference the per-stage aggregator rules.
rule all:
    default_target: True
    input:
        rules.all_sequence_counts.input,
        rules.all_variant_relationships.input,
        rules.all_mlr_estimates.input,
        rules.all_fitness_flux.input,
        rules.all_lineage_deltas.input,

rule clean:
    """
    Remove everything the workflow generates so the repo can be rerun from
    scratch: the upstream sequence-counts/ and mlr-estimates/, the logs, and the
    analysis results/. Leaves the provisioned raw metadata in data/ in place.
    """
    shell:
        """
        rm -rf sequence-counts \
               mlr-estimates \
               logs \
               fitness-flux-analysis/results \
               lineage-deltas-analysis/results
        """

rule clean_analysis:
    """
    Remove only the analysis intermediates generated by the fitness-flux and
    lineage-deltas rules, leaving the upstream sequence-counts/ and
    mlr-estimates/ outputs intact.
    """
    shell:
        """
        rm -rf fitness-flux-analysis/results \
               lineage-deltas-analysis/results \
               logs/fitness_flux \
               logs/lineage_deltas
        """
